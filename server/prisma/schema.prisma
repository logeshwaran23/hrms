generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── RBAC ────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  roleId       String    @map("role_id")
  employeeId   String?   @unique @map("employee_id")
  status       String    @default("ACTIVE")
  lastLogin    DateTime? @map("last_login")
  mfaEnabled   Boolean   @default(false) @map("mfa_enabled")
  refreshToken String?   @map("refresh_token")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  role          Role           @relation(fields: [roleId], references: [id])
  employee      Employee?      @relation(fields: [employeeId], references: [id])
  auditLogs     AuditLog[]
  notifications Notification[]

  @@map("users")
}

model Role {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  isSystemRole Boolean  @default(false) @map("is_system_role")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(cuid())
  resource  String
  action    String
  scope     String?
  createdAt DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@unique([resource, action, scope])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ─── ORGANIZATION ────────────────────────────────────────────────

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  headId    String?  @map("head_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  head         Employee?     @relation("DepartmentHead", fields: [headId], references: [id])
  employees    Employee[]    @relation("EmployeeDepartment")
  designations Designation[]

  @@map("departments")
}

model Designation {
  id           String   @id @default(cuid())
  name         String
  departmentId String   @map("department_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  department Department @relation(fields: [departmentId], references: [id])
  employees  Employee[]

  @@unique([name, departmentId])
  @@map("designations")
}

// ─── EMPLOYEE ────────────────────────────────────────────────────

model Employee {
  id               String    @id @default(cuid())
  employeeCode     String    @unique @map("employee_code")
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  email            String    @unique
  phone            String?
  dateOfBirth      DateTime? @map("date_of_birth")
  dateOfJoining    DateTime  @map("date_of_joining")
  gender           String?
  maritalStatus    String?   @map("marital_status")
  bloodGroup       String?   @map("blood_group")
  address          String?
  city             String?
  state            String?
  pincode          String?
  emergencyContact String?   @map("emergency_contact")
  emergencyPhone   String?   @map("emergency_phone")
  bankName         String?   @map("bank_name")
  bankAccount      String?   @map("bank_account")
  ifscCode         String?   @map("ifsc_code")
  panNumber        String?   @map("pan_number")
  aadharNumber     String?   @map("aadhar_number")
  avatar           String?
  departmentId     String    @map("department_id")
  designationId    String    @map("designation_id")
  managerId        String?   @map("manager_id")
  status           String    @default("ACTIVE")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  department        Department   @relation("EmployeeDepartment", fields: [departmentId], references: [id])
  designation       Designation  @relation(fields: [designationId], references: [id])
  manager           Employee?    @relation("ManagerReports", fields: [managerId], references: [id])
  directReports     Employee[]   @relation("ManagerReports")
  headOfDepartments Department[] @relation("DepartmentHead")

  user                    User?
  leaveBalances           LeaveBalance[]
  leaveRequests           LeaveRequest[]   @relation("EmployeeLeaves")
  approvedLeaves          LeaveRequest[]   @relation("LeaveApprover")
  attendances             Attendance[]
  regularizations         Regularization[] @relation("EmployeeRegularizations")
  approvedRegularizations Regularization[] @relation("RegularizationApprover")
  eodReports              EODReport[]
  documents               Document[]
  payslips                Payslip[]
  payslipRequests         PayslipRequest[]
  tickets                 Ticket[]         @relation("TicketCreator")
  assignedTickets         Ticket[]         @relation("TicketAssignee")

  @@map("employees")
}

// ─── LEAVE MANAGEMENT ────────────────────────────────────────────

model LeaveType {
  id             String   @id @default(cuid())
  name           String   @unique
  defaultBalance Int      @map("default_balance")
  carryForward   Boolean  @default(false) @map("carry_forward")
  maxCarryDays   Int      @default(0) @map("max_carry_days")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  balances LeaveBalance[]
  requests LeaveRequest[]

  @@map("leave_types")
}

model LeaveBalance {
  id          String   @id @default(cuid())
  employeeId  String   @map("employee_id")
  leaveTypeId String   @map("leave_type_id")
  year        Int
  allocated   Float    @default(0)
  used        Float    @default(0)
  remaining   Float    @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id              String    @id @default(cuid())
  employeeId      String    @map("employee_id")
  leaveTypeId     String    @map("leave_type_id")
  startDate       DateTime  @map("start_date")
  endDate         DateTime  @map("end_date")
  duration        Float
  durationType    String    @default("FULL_DAY") @map("duration_type")
  reason          String
  status          String    @default("PENDING")
  approverId      String?   @map("approver_id")
  approverComment String?   @map("approver_comment")
  approvedAt      DateTime? @map("approved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  employee  Employee  @relation("EmployeeLeaves", fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])
  approver  Employee? @relation("LeaveApprover", fields: [approverId], references: [id])

  @@map("leave_requests")
}

// ─── ATTENDANCE ──────────────────────────────────────────────────

model Attendance {
  id         String    @id @default(cuid())
  employeeId String    @map("employee_id")
  date       DateTime
  checkIn    DateTime? @map("check_in")
  checkOut   DateTime? @map("check_out")
  workHours  Float?    @map("work_hours")
  status     String    @default("ABSENT")
  source     String    @default("MANUAL")
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  employee       Employee        @relation(fields: [employeeId], references: [id])
  regularization Regularization?

  @@unique([employeeId, date])
  @@map("attendances")
}

model Regularization {
  id                String    @id @default(cuid())
  attendanceId      String    @unique @map("attendance_id")
  employeeId        String    @map("employee_id")
  reason            String
  requestedCheckIn  DateTime? @map("requested_check_in")
  requestedCheckOut DateTime? @map("requested_check_out")
  status            String    @default("PENDING")
  approverId        String?   @map("approver_id")
  approverComment   String?   @map("approver_comment")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  attendance Attendance @relation(fields: [attendanceId], references: [id])
  employee   Employee   @relation("EmployeeRegularizations", fields: [employeeId], references: [id])
  approver   Employee?  @relation("RegularizationApprover", fields: [approverId], references: [id])

  @@map("regularizations")
}

// ─── EOD REPORTS ─────────────────────────────────────────────────

model EODReport {
  id             String   @id @default(cuid())
  employeeId     String   @map("employee_id")
  date           DateTime
  summary        String
  completedTasks String   @map("completed_tasks")
  workLocation   String   @default("Office") @map("work_location")
  extraHours     Float    @default(0) @map("extra_hours")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@map("eod_reports")
}

// ─── DOCUMENTS ───────────────────────────────────────────────────

model Document {
  id         String   @id @default(cuid())
  employeeId String   @map("employee_id")
  name       String
  type       String
  filePath   String   @map("file_path")
  fileSize   Int?     @map("file_size")
  mimeType   String?  @map("mime_type")
  verified   Boolean  @default(false)
  verifiedBy String?  @map("verified_by")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("documents")
}

// ─── PAYROLL ─────────────────────────────────────────────────────

model Payslip {
  id              String   @id @default(cuid())
  employeeId      String   @map("employee_id")
  month           Int
  year            Int
  basicSalary     Float    @map("basic_salary")
  hra             Float    @default(0)
  allowances      Float    @default(0)
  grossSalary     Float    @map("gross_salary")
  pf              Float    @default(0)
  tax             Float    @default(0)
  otherDeductions Float    @default(0) @map("other_deductions")
  totalDeductions Float    @map("total_deductions")
  netSalary       Float    @map("net_salary")
  filePath        String?  @map("file_path")
  status          String   @default("DRAFT")
  generatedAt     DateTime @default(now()) @map("generated_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
  @@map("payslips")
}

model PayslipRequest {
  id         String   @id @default(cuid())
  employeeId String   @map("employee_id")
  month      Int
  year       Int
  purpose    String
  status     String   @default("PENDING")
  remarks    String?
  filePath   String?  @map("file_path")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("payslip_requests")
}

// ─── HELPDESK ────────────────────────────────────────────────────

model Ticket {
  id          String    @id @default(cuid())
  employeeId  String    @map("employee_id")
  category    String
  subject     String
  description String
  status      String    @default("OPEN")
  priority    String    @default("MEDIUM")
  assignedTo  String?   @map("assigned_to")
  resolution  String?
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  employee Employee  @relation("TicketCreator", fields: [employeeId], references: [id])
  assignee Employee? @relation("TicketAssignee", fields: [assignedTo], references: [id])

  @@map("tickets")
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  type      String   @default("INFO")
  link      String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ─── AUDIT LOG ───────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([resource, action])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── SYSTEM CONFIG ───────────────────────────────────────────────

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedBy String?  @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

model Holiday {
  id        String   @id @default(cuid())
  name      String
  date      DateTime
  type      String   @default("GENERAL")
  year      Int
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([date, name])
  @@map("holidays")
}

// ─── PERFORMANCE MANAGEMENT ───────────────────────────────────────

model PerformanceGoal {
  id          String   @id @default(cuid())
  employeeId  String   @map("employee_id")
  title       String
  description String
  status      String   @default("NOT_STARTED")
  progress    Int      @default(0)
  dueDate     String   @map("due_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("performance_goals")
}

model PerformanceAppraisal {
  id          String   @id @default(cuid())
  employeeId  String   @map("employee_id")
  year        Int
  rating      Float
  feedback    String
  managerId   String   @map("manager_id")
  managerName String   @map("manager_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("performance_appraisals")
}

// ─── RECRUITMENT ──────────────────────────────────────────────────

model JobPosting {
  id         String   @id @default(cuid())
  title      String
  department String
  location   String
  type       String
  status     String   @default("OPEN")
  postedDate String   @map("posted_date")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("job_postings")
}

model Candidate {
  id          String   @id @default(cuid())
  jobId       String   @map("job_id")
  name        String
  email       String
  status      String   @default("SCREENING")
  appliedDate String   @map("applied_date")
  resumeUrl   String?  @map("resume_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("candidates")
}
